nextflow.enable.dsl = 2

params {
    input = null
    outdir = 'results'

    run_label = 'production'

    qc_sif = '/data/software/singularity/qc_fastqc_multiqc.sif'
    cutadapt_sif = '/data/software/singularity/read_cleanup_cutadapt-5.2.sif'
    qiime_sif = '/data/software/singularity/qiime2_amplicon_2025.7.sif'

    // Use the ITSxpress-enabled QIIME 2 deployment.
    qiime_its_sif = '/data/software/singularity/build/qiime2_its_2025.7.sandbox'

    adapter_trim = true
    adapter_f = 'CTGTCTCTTATACACATCTCCGAGCCCACGAGAC'
    adapter_r = 'CTGTCTCTTATACACATCTGACGCTGCCGACGA'

    poly_g_trim = true
    poly_g_min_run = 10

    quality_trim = false
    quality_cutoff = 30

    // Remove empty or very short reads before QIIME 2 import.
    apply_min_length = true
    min_length = 50

    // Default production preprocessing strategy.
    preprocess_method = 'itsxpress'
    analysis_mode = 'paired'

    // Primer settings must be provided in study-specific YAML files
    // when the primer branch is used.
    primer_fwd = ''
    primer_rev = ''
    primer_fwd_adapter = ''
    primer_rev_adapter = ''
    primer_discard_untrimmed = false

    // Default ITSxpress settings.
    itsxpress_taxa = 'F'
    itsxpress_cluster_id = 1.0
}

process {
    executor = 'local'
    shell = ['/bin/bash', '-euo', 'pipefail']

    withLabel: qc {
        cpus = 4
        memory = '8 GB'
    }

    withLabel: read_cleanup {
        cpus = 4
        memory = '8 GB'
    }

    withLabel: qiime_import {
        cpus = 4
        memory = '16 GB'
    }

    withLabel: qiime_preprocess {
        cpus = 4
        memory = '16 GB'
    }
}

singularity {
    enabled = true
    autoMounts = true
}
