nextflow.enable.dsl = 2

params {
    input = null
    outdir = 'results'

    run_label = 'production'

    qc_sif = '/data/software/singularity/qc_fastqc_multiqc.sif'
    cutadapt_sif = '/data/software/singularity/read_cleanup_cutadapt-5.2.sif'
    qiime_sif = '/data/software/singularity/qiime2_amplicon_2025.7.sif'
    qiime_its_sif = '/data/software/singularity/build/qiime2_its_2025.7.sandbox'

    adapter_trim = true
    adapter_f = 'CTGTCTCTTATACACATCTCCGAGCCCACGAGAC'
    adapter_r = 'CTGTCTTATACACATCTGACGCTGCCGACGA'

    poly_g_trim = true
    poly_g_min_run = 10

    quality_trim = false
    quality_cutoff = 30

    apply_min_length = true
    min_length = 50

    preprocess_method = 'itsxpress'
    analysis_mode = 'paired'

    primer_fwd = ''
    primer_rev = ''
    primer_fwd_adapter = ''
    primer_rev_adapter = ''
    primer_discard_untrimmed = false

    itsxpress_taxa = 'F'
    itsxpress_cluster_id = 1.0

    taxonomy_enabled = true
    taxonomy_qiime_sif = null
    taxonomy_reference_id = 'unite_ver10_99'
    taxonomy_classifier = '/data/Reference/QIIME2-2024.10/Fungi/UNITE/10.0/unite_ver10_99_19.02.2025-Q2-2024.10.qza'
    taxonomy_reads_per_batch = 'auto'
    taxonomy_confidence = 0.7

    // RefSeq ITS BLAST reconciliation is disabled by default.
    blast_refseq_enabled = false
    blast_taxonomy_sif = '/data/software/singularity/itsdetector/blast_taxonomy_2026-06.sif'
    blast_db = '/data/Reference/BLAST/ITS/20250604/ITS_RefSeq_Fungi'
    taxdump_dir = '/data/Reference/BLAST/taxdump'

    blast_retrieval_n = 20
    blast_top_n = 5
    blast_max_evalue = 1e-10
    blast_min_pident = 99.0
    blast_min_qcovus = 80.0
    blast_min_qiime_confidence = 0.7
    taxonomy_profile = 'unite'
}

process {
    executor = 'local'
    shell = ['/bin/bash', '-euo', 'pipefail']

    withLabel: qc {
        cpus = 4
        memory = '8 GB'
    }

    withLabel: read_cleanup {
        cpus = 4
        memory = '8 GB'
    }

    withLabel: qiime_import {
        cpus = 4
        memory = '16 GB'
    }

    withLabel: qiime_preprocess {
        cpus = 4
        memory = '16 GB'
    }

    withLabel: qiime_dada2 {
        cpus = 4
        memory = '16 GB'
    }

    withLabel: qiime_taxonomy {
        cpus = 4
        memory = '32 GB'
    }

    withLabel: qiime_taxonomy_import {
        cpus = 4
        memory = '16 GB'
    }

    withLabel: blast_taxonomy {
        cpus = 8
        memory = '32 GB'
    }
}

singularity {
    enabled = true
    autoMounts = true
}
